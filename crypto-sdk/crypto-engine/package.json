{
  "name": "@securechat/crypto-engine",
  "version": "1.0.0",
  "description": "Layer 2 / Sprint 3 — reusable Cryptographic Engine built on @securechat/crypto-sdk. Symmetric/streaming encryption, signature & payload framework, key derivation, file encryption, integrity, benchmarking, and security utilities. No chat/transport/auth coupling.",
  "type": "module",
  "license": "ISC",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest run tests/benchmark.test.ts"
  },
  "keywords": [
    "cryptography",
    "aead",
    "streaming-encryption",
    "file-encryption",
    "signatures",
    "key-derivation",
    "engine"
  ],
  "dependencies": {
    "@securechat/crypto-sdk": "file:.."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
