{
  "name": "@securechat/key-management",
  "version": "1.0.0",
  "description": "Layer 2 / Sprint 2 — reusable Key Management System built on top of @securechat/crypto-sdk. Manages key lifecycle, storage, repositories, metadata, serialization, validation, rotation, and caching. No chat/transport/auth/DB coupling.",
  "type": "module",
  "license": "ISC",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "key-management",
    "kms",
    "key-rotation",
    "key-storage",
    "crypto"
  ],
  "dependencies": {
    "@securechat/crypto-sdk": "file:.."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
