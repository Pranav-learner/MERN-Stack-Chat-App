{
  "name": "@securechat/crypto-sdk",
  "version": "1.0.0",
  "description": "Layer 2 / Module 1 — isolated cryptographic foundation for the Secure Hybrid Distributed Messaging Platform. Reusable primitives only: no chat, transport, auth, or persistence coupling.",
  "type": "module",
  "license": "ISC",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cryptography",
    "e2ee",
    "aes-256-gcm",
    "x25519",
    "ed25519",
    "hkdf",
    "sdk"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
